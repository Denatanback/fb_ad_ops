model NotificationDelivery {
  id                   String                     @id @default(cuid()) @map("id")
  importRunId          String?                    @map("import_run_id")
  alertEventId         String?                    @map("alert_event_id")
  notificationDigestId String?                    @map("notification_digest_id")
  channel              NotificationChannel        @default(TELEGRAM) @map("channel")
  deliveryStatus       NotificationDeliveryStatus @default(PENDING) @map("delivery_status")
  destinationTopicKey  String?                    @map("destination_topic_key")
  telegramChatId       String?                    @map("telegram_chat_id")
  telegramThreadId     Int?                       @map("telegram_thread_id")
  attemptedAt          DateTime?                  @map("attempted_at")
  deliveredAt          DateTime?                  @map("delivered_at")
  failedAt             DateTime?                  @map("failed_at")
  providerMessageId    String?                    @map("provider_message_id")
  errorMessage         String?                    @map("error_message")
  providerPayload      Json?                      @map("provider_payload")
  createdAt            DateTime                   @default(now()) @map("created_at")
  updatedAt            DateTime                   @updatedAt @map("updated_at")

  importRun          ImportRun?          @relation(fields: [importRunId], references: [id], onDelete: SetNull)
  alertEvent         AlertEvent?         @relation(fields: [alertEventId], references: [id], onDelete: SetNull)
  notificationDigest NotificationDigest? @relation(fields: [notificationDigestId], references: [id], onDelete: SetNull)

  @@index([importRunId])
  @@index([alertEventId])
  @@index([notificationDigestId])
  @@index([channel, deliveryStatus])
  @@index([destinationTopicKey])
  @@map("notification_deliveries")
}

model AdAccount {
  id         String    @id @default(cuid()) @map("id")
  accountId  String    @unique @map("account_id")
  tag        String    @map("tag")
  ownerId    String?   @map("owner_id")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  importRuns ImportRun[]

  @@index([isActive])
  @@map("ad_accounts")
}
